# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Default channel (fallback)
DISCORD_CHANNEL_ID=your_discord_channel_id_here

# Optional: channel for scheduled reminders (H-7, H-1, Hari H)
REMINDER_CHANNEL_ID=your_discord_channel_id_here

# Optional: channel for "new booking / new event" notifications
NEW_EVENT_CHANNEL_ID=your_discord_channel_id_here

# Google Calendar Configuration
GOOGLE_CALENDAR_ID=your_calendar_id@example.com

# Service account key:
# - Either JSON string (one line), or
# - Path to JSON file (relative/absolute), e.g. ./credentials/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_KEY=./credentials/google-service-account.json

# Timezone (default: Asia/Jakarta)
TIMEZONE=Asia/Jakarta

